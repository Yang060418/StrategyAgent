# ==========================================
# STRATEGY IDEATION ENGINE - API CONFIGURATION
# ==========================================

# MANDATORY: Set at least one LLM Provider API Key
GROQ_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# MANDATORY for Data Ingestion:
# FRED (Macro): https://fredaccount.stlouisfed.org/apikeys
FRED_API_KEY=

# Tavily (Search): https://tavily.com/
TAVILY_API_KEY=

# Alpha Vantage (Technicals): https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=

# OPTIONAL: SEC EDGAR User-Agent (e.g. "Name email@domain.com")
SEC_EDGAR_USER_AGENT=

# Operational Settings
LOG_LEVEL=INFO
EXPORT_DIR=exports

# Model Tiering (Supports prefixes: groq/, openai/, anthropic/, gemini/)
# You can mix and match models from different providers for each tier.
SCOUT_MODEL=groq/llama-3.1-8b-instant
STRATEGIST_MODEL=groq/llama-3.3-70b-versatile
CRITIC_MODEL=groq/llama-3.3-70b-versatile
DSPY_MAX_TOKENS=8192
