# ==========================================
# STRATEGY IDEATION ENGINE - API CONFIGURATION
# ==========================================

# MANDATORY: Primary LLM Provider API Key (e.g. Groq, OpenRouter)
PROVIDER_API_KEY=your_key_here

# OPTIONAL: Other LLM Providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# MANDATORY for Data Ingestion:
# FRED (Macro): https://fredaccount.stlouisfed.org/apikeys
FRED_API_KEY=your_key_here

# Tavily (Search): https://tavily.com/
TAVILY_API_KEY=your_key_here

# Alpha Vantage (Technicals): https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=your_key_here

# OPTIONAL: SEC EDGAR User-Agent (e.g. "Name email@domain.com")
SEC_EDGAR_USER_AGENT=

# Operational Settings
LOG_LEVEL=INFO
EXPORT_DIR=exports

# Model Tiering (Configure based on your provider)
SCOUT_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
STRATEGIST_MODEL=moonshotai/kimi-k2-instruct
CRITIC_MODEL=moonshotai/kimi-k2-instruct
DSPY_MAX_TOKENS=8192
